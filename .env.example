# Copy to ".env" (project root, next to app.py). Do not commit .env.

# Canonical public site (use the hostname customers see; Stripe + email image URLs)
# SITE_URL=https://www.licoricelocker.com
# Optional: override base for email images only (defaults to SITE_URL / Railway / www fallback)
# EMAIL_PUBLIC_BASE_URL=https://www.licoricelocker.com

RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Licorice Locker <orders@your-verified-domain.com>
ADMIN_ORDER_EMAIL=you@example.com

